---
import BaseLayout from "../layouts/BaseLayout.astro";
import { deploymentPhases, projects } from "../data/projects";
---

<BaseLayout title="Deployment Roadmap - Hao Hu">
  <section class="page-heading">
    <p class="eyebrow">Roadmap</p>
    <h1>Personal site and remote demo deployment</h1>
    <p>
      A static portfolio ships first. Live demos are then added behind one
      domain with Nginx subpath routing, private service ports, and demo-only
      data.
    </p>
  </section>

  <section class="section">
    <h2>Phases</h2>
    <ol class="phase-list large">
      {deploymentPhases.map((phase) => <li>{phase}</li>)}
    </ol>
  </section>

  <section class="section detail-grid">
    <article>
      <p class="eyebrow">Nginx routing</p>
      <h2>One domain, clear paths</h2>
      <div class="route-table">
        <div><span>Portfolio</span><code>/</code></div>
        <div><span>Enterprise RAG</span><code>/demos/enterprise-rag/</code></div>
        <div><span>NL2SQL Agent</span><code>/demos/nl2sql/</code></div>
        <div><span>E-Commerce Agent</span><code>/demos/ecommerce/</code></div>
      </div>
    </article>
    <article>
      <p class="eyebrow">Hardening</p>
      <h2>Public demo defaults</h2>
      <ul class="check-list">
        <li>Use demo-only data and API keys.</li>
        <li>Keep databases, MCP servers, and internal health endpoints private.</li>
        <li>Add service tokens to MCP endpoints outside local development.</li>
        <li>Show screenshots when a live demo is offline.</li>
      </ul>
    </article>
  </section>

  <section class="section">
    <h2>Demo order</h2>
    <div class="project-grid compact">
      {projects.map((project, index) => (
        <article class="project-card">
          <div class="project-card-body">
            <span class="step-number">{index + 1}</span>
            <h3>{project.shortTitle}</h3>
            <p>{project.deploymentNotes[0]}</p>
            <a class="text-link" href={`/projects/${project.slug}/`}>Project plan</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
