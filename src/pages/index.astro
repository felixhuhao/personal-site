---
import BaseLayout from "../layouts/BaseLayout.astro";
import { deploymentPhases, projects } from "../data/projects";

const orderedProjects = projects;
---

<BaseLayout>
  <section class="hero-section">
    <div class="hero-copy">
      <p class="eyebrow">Portfolio and demo hub</p>
      <h1>Production-shaped AI agent projects</h1>
      <p class="hero-text">
        Three systems showing retrieval, guarded analytics, MCP tooling,
        approval flows, evaluation, and deployment-ready service boundaries.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="#projects">View projects</a>
        <a class="button button-secondary" href="/roadmap/">Deployment roadmap</a>
      </div>
    </div>
    <div class="hero-panel" aria-label="Deployment overview">
      <div class="map-row">
        <span>Static site</span>
        <strong>/</strong>
      </div>
      <div class="map-row">
        <span>Enterprise RAG</span>
        <strong>/demos/enterprise-rag/</strong>
      </div>
      <div class="map-row">
        <span>NL2SQL Agent</span>
        <strong>/demos/nl2sql/</strong>
      </div>
      <div class="map-row">
        <span>E-Commerce Agent</span>
        <strong>/demos/ecommerce/</strong>
      </div>
    </div>
  </section>

  <section class="section" id="projects">
    <div class="section-heading">
      <p class="eyebrow">Selected work</p>
      <h2>Project systems</h2>
    </div>
    <div class="project-grid">
      {
        orderedProjects.map((project) => (
          <article class="project-card">
            <a class="project-image-link" href={`/projects/${project.slug}/`}>
              <img src={project.image} alt={`${project.shortTitle} interface preview`} loading="lazy" />
            </a>
            <div class="project-card-body">
              <div class="card-title-row">
                <h3>{project.shortTitle}</h3>
                <span class={`status status-${project.status.toLowerCase().replaceAll(" ", "-")}`}>
                  {project.status}
                </span>
              </div>
              <p>{project.summary}</p>
              <div class="tag-row">
                {project.stack.slice(0, 4).map((item) => <span>{item}</span>)}
              </div>
              <div class="card-actions">
                <a class="text-link" href={`/projects/${project.slug}/`}>Project details</a>
                <a class="text-link muted" href={project.repos[0].url}>GitHub</a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section split-section">
    <div>
      <p class="eyebrow">Deployment path</p>
      <h2>Remote server rollout</h2>
      <p>
        The site is static first, with demo services added behind the same
        domain through Nginx subpaths. Each demo keeps data, secrets, and
        health checks isolated.
      </p>
    </div>
    <ol class="phase-list">
      {deploymentPhases.map((phase) => <li>{phase}</li>)}
    </ol>
  </section>
</BaseLayout>
