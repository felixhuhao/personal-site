---
import BaseLayout from "../layouts/BaseLayout.astro";
import { deploymentPhases, projects } from "../data/projects";
---

<BaseLayout title="Deployment Roadmap - Hao Hu">
  <section class="page-heading">
    <p class="eyebrow">Roadmap</p>
    <h1>Personal site and remote demo deployment</h1>
    <p>
      The demos are live over HTTP on one public IP with separate ports. The
      next infrastructure step is adding a domain, HTTPS, and Nginx routing.
    </p>
  </section>

  <section class="section">
    <h2>Phases</h2>
    <ol class="phase-list large">
      {deploymentPhases.map((phase) => <li>{phase}</li>)}
    </ol>
  </section>

  <section class="section detail-grid">
    <article>
      <p class="eyebrow">Current routing</p>
      <h2>HTTP IP and ports</h2>
      <div class="route-table">
        {projects.map((project) => <div><span>{project.shortTitle}</span><code>{project.demoUrl}</code></div>)}
      </div>
    </article>
    <article>
      <p class="eyebrow">Hardening</p>
      <h2>Public demo defaults</h2>
      <ul class="check-list">
        <li>Use demo-only data and API keys.</li>
        <li>Keep databases, MCP servers, and internal health endpoints private.</li>
        <li>Add service tokens to MCP endpoints outside local development.</li>
        <li>Move public access to HTTPS once a domain is available.</li>
        <li>Show screenshots or fallback pages when a live demo is offline.</li>
      </ul>
    </article>
  </section>

  <section class="section">
    <h2>Demo order</h2>
    <div class="project-grid compact">
      {projects.map((project, index) => (
        <article class="project-card">
          <div class="project-card-body">
            <span class="step-number">{index + 1}</span>
            <h3>{project.shortTitle}</h3>
            <p>{project.deploymentNotes[0]}</p>
            <a class="text-link" href={`/projects/${project.slug}/`}>Project plan</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
