---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
import { profile, about, experience, skills, labProjects } from "../data/profile";
---

<BaseLayout>
  <!-- Hero -->
  <section class="hero">
    <div class="wrap hero-inner">
      <p class="hero-eyebrow">{profile.heroEyebrow}</p>
      <h1>
        {profile.heroHeadlinePrefix}<span class="grad">{profile.heroHeadlineAccent}</span>{profile.heroHeadlineSuffix}
      </h1>
      <p class="hero-lead">{profile.heroSub}</p>

      <div class="hero-proof" aria-label="Career proof points">
        <div class="pedigree-strip">
          <div class="pedigree-companies">
            {profile.pedigree.map((company) => <strong>{company}</strong>)}
          </div>
          <span>{profile.currentRole}</span>
        </div>
        <div class="hero-metrics">
          {profile.heroMetrics.map((metric) => <span>{metric}</span>)}
        </div>
        <div class="hero-skills">
          {profile.heroSkills.map((skill) => <span>{skill}</span>)}
        </div>
      </div>

      <div class="hero-actions">
        <a class="btn btn-primary" href="#projects">View work</a>
        <a class="btn btn-ghost" href={profile.resumeUrl} target="_blank" rel="noopener">Résumé (PDF)</a>
        <a class="btn btn-ghost" href={profile.github} target="_blank" rel="noopener">GitHub</a>
      </div>
      <div class="hero-meta">
        <span>{profile.location}</span>
        <a href={`mailto:${profile.email}`}>{profile.email}</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="section" id="about">
    <div class="wrap">
      <div class="section-head"><p class="eyebrow">About</p><h2>Leader who builds.</h2></div>
      <div class="about-grid">
        <div>
          {about.paragraphs.map((p) => <p set:html={p} />)}
        </div>
        <div>
          <p class="pov-label">How I build AI that holds up</p>
          <div class="pillars">
            {about.pillars.map((pl) => (
              <div class="pillar"><h3>{pl.title}</h3><p>{pl.body}</p></div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section class="section" id="projects">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Selected work</p>
        <h2>One ERP AI layer: knowledge, analytics, operations.</h2>
        <p>
          Three production systems built for one enterprise ERP client, sharing one safety
          and evaluation practice — an operations copilot, a self-service analytics agent,
          and a knowledge assistant.
        </p>
        <div class="section-cta"><a class="btn btn-primary" href="/work/erp-ai-layer/">Read the full case study →</a></div>
      </div>
      <div class="proj-grid">
        {
          projects.map((p) => (
            <article class="card">
              <a class="card-media" href={`/projects/${p.slug}/`}>
                <img src={p.image} alt={`${p.shortTitle} preview`} loading="lazy" />
              </a>
              <div class="card-body">
                <span class="card-kicker">{p.kicker}</span>
                <h3>{p.title}</h3>
                <p>{p.summary}</p>
                <div class="tag-row">{p.stack.slice(0, 4).map((t) => <span class="tag">{t}</span>)}</div>
                <div class="card-links">
                  <a href={`/projects/${p.slug}/`}>Deep dive →</a>
                  {p.demoUrl && <a href={p.demoUrl} target="_blank" rel="noopener">Live demo (login-gated)</a>}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section class="section" id="experience">
    <div class="wrap">
      <div class="section-head"><p class="eyebrow">Experience</p><h2>10+ years, top to bottom of the stack.</h2></div>
      <div class="xp">
        {
          experience.map((x) => (
            <div class="xp-item">
              <div class="xp-when">{x.when}</div>
              <div>
                <div><span class="xp-role">{x.role}</span> · <span class="xp-co">{x.company}</span></div>
                <div class="xp-detail">{x.detail}</div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Lab -->
  <section class="section" id="lab">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Lab</p>
        <h2>Personal R&amp;D.</h2>
        <p>Self-directed prototypes exploring multimodal RAG, multi-agent systems, and classical ML.</p>
      </div>
      <div class="lab-grid">
        {
          labProjects.map((l) => (
            <article class="lab-card">
              <h3>{l.title}</h3>
              <p>{l.blurb}</p>
              <div class="tag-row">{l.tags.map((t) => <span class="tag">{t}</span>)}</div>
              <div class="card-links"><a href={l.repo}>GitHub →</a></div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="section" id="skills">
    <div class="wrap">
      <div class="section-head"><p class="eyebrow">Skills</p><h2>Technical toolkit.</h2></div>
      <div class="skill-grid">
        {
          skills.map((s) => (
            <div class="skill-cat">
              <h3>{s.cat}</h3>
              <div class="tag-row">{s.items.map((i) => <span class="tag">{i}</span>)}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="contact" id="contact">
    <div class="wrap">
      <p class="eyebrow">Contact</p>
      <h2>Let's build something reliable.</h2>
      <p>Open to AI/agentic engineering and staff-level roles, and consulting engagements.</p>
      <div class="contact-actions">
        <a class="btn btn-primary" href={`mailto:${profile.email}`}>{profile.email}</a>
        <a class="btn btn-ghost" href={profile.github}>GitHub</a>
        <a class="btn btn-ghost" href={profile.resumeUrl}>Résumé (PDF)</a>
      </div>
    </div>
  </section>
</BaseLayout>
